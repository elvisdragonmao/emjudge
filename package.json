{
	"private": true,
	"scripts": {
		"build": "pnpm run -r build",
		"db:migrate": "pnpm --filter @judge/api db:migrate",
		"db:seed": "pnpm --filter @judge/api db:seed",
		"dev": "pnpm --filter @judge/api --filter @judge/web -r --parallel dev",
		"dev:api": "pnpm --filter @judge/api dev",
		"dev:web": "pnpm --filter @judge/web dev",
		"dev:worker": "pnpm --filter @judge/worker dev",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"lint": "pnpm run -r --if-present lint",
		"prepare": "husky"
	},
	"devDependencies": {
		"husky": "^9.1.7",
		"prettier": "^3.8.1",
		"prettier-plugin-organize-imports": "^4.3.0",
		"prettier-plugin-packagejson": "^3.0.2"
	},
	"packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be",
	"pnpm": {
		"onlyBuiltDependencies": [
			"bcrypt",
			"esbuild"
		]
	}
}
