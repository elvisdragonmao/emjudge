{
	"private": true,
	"scripts": {
		"build": "pnpm run -r build",
		"db:migrate": "pnpm --filter @judge/api db:migrate",
		"db:seed": "pnpm --filter @judge/api db:seed",
		"dev": "pnpm --filter @judge/api --filter @judge/web -r --parallel dev",
		"dev:api": "pnpm --filter @judge/api dev",
		"dev:web": "pnpm --filter @judge/web dev",
		"dev:worker": "pnpm --filter @judge/worker dev",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"lint": "pnpm run -r --if-present lint",
		"prepare": "husky"
	},
	"devDependencies": {
		"husky": "^9.1.7",
		"prettier": "^3.8.1",
		"prettier-plugin-organize-imports": "^4.3.0",
		"prettier-plugin-packagejson": "^3.0.2"
	},
	"packageManager": "pnpm@11.0.9+sha512.34ce82e6780233cf9cad8685029a8f81d2e06196c5a9bad98879f7424940c6817c4e4524fb7d38b8553ceed48b9758b8ebaf1abd3600c232c4c8cf7366086f38",
	"pnpm": {
		"onlyBuiltDependencies": [
			"bcrypt",
			"esbuild"
		]
	}
}
